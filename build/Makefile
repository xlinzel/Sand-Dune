	$(MAKE) $(MAKESILENT) -f CMakeFiles/dune_core.dir/build.make CMakeFiles/dune_core.dir/src/wind/vectorfield.cpp.i
.PHONY : src/wind/vectorfield.cpp.i

src/wind/vectorfield.s: src/wind/vectorfield.cpp.s
.PHONY : src/wind/vectorfield.s

# target to generate assembly for a file
src/wind/vectorfield.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/dune_core.dir/build.make CMakeFiles/dune_core.dir/src/wind/vectorfield.cpp.s
.PHONY : src/wind/vectorfield.cpp.s

tests/test.o: tests/test.cpp.o
.PHONY : tests/test.o

